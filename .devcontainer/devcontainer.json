{
  "name": "Django Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${env:HOME}/.ssh/id_rsa,target=/root/.ssh/id_rsa,type=bind,consistency=cached",
    "source=${env:HOME}/.ssh/known_hosts,target=/root/.ssh/known_hosts,type=bind,consistency=cached"
  ],
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit",
            "source.fixAll": "explicit"
          }
        },
        "files.exclude": {
          "**/__pycache__": true,
          "**/*.pyc": true
        },
        "tailwindCSS.includeLanguages": {
          "django-html": "html",
          "django-txt": "html"
        },
        "files.associations": {
          "**/*.html": "django-html"
        },
        "[django-html]": {
          "editor.defaultFormatter": "monosans.djlint",
          "editor.formatOnSave": true
        },
        "djlint.ignore": ["H021"]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "bradlc.vscode-tailwindcss",
        "batisteo.vscode-django",
        "monosans.djlint",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "postCreateCommand": "poetry install",
  "remoteUser": "vscode"
}
